# =============================================================================
# Barnett Art Platform — Environment variables (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for LOCAL development.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
#
# NEVER commit a real `.env`. Production secrets live in the Vercel dashboard
# and AWS Secrets Manager — not in this repo. See docs/EXTERNAL-SETUP.md.
# Every variable here is validated at boot by src/lib/env.ts (Zod). A missing
# or malformed value fails fast with a clear error rather than at runtime.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the site. Used for absolute links, canonical URLs, Stripe
# return URLs, and sitemap generation.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# "development" | "production" | "test" — usually set by the platform.
NODE_ENV="development"

# --- Demo / prototype mode ---------------------------------------------------
# "true" serves a curated in-repo catalog of sample paintings with NO database
# and NO payment provider — lets a Vercel preview run with zero external
# services (checkout is disabled). Leave blank/false for the real app.
DEMO_MODE=""

# --- Database (PostgreSQL via Drizzle) ---------------------------------------
# Local dev points at the Docker Compose Postgres (see docker-compose.yml).
# Production uses the Neon connection string (pooled). Always require SSL in prod.
DATABASE_URL="postgresql://barnett:barnett_dev_password@localhost:5432/barnett_art"

# --- Stripe (TEST keys for local; LIVE keys only in Vercel prod) -------------
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_<your-test-secret-key>"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_<your-test-publishable-key>"
# Webhook signing secret from `stripe listen` (local) or the dashboard (prod).
# This is what proves a webhook really came from Stripe — required, never skip.
STRIPE_WEBHOOK_SECRET="whsec_<from-stripe-listen>"

# --- Rate limiting (Upstash Redis) -------------------------------------------
# Free tier at https://console.upstash.com — create a Redis database.
# If both are empty in development, rate limiting falls back to in-memory.
# In production these are REQUIRED.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Email (Resend) ----------------------------------------------------------
# Transactional order confirmations. https://resend.com/api-keys
RESEND_API_KEY="re_<your-resend-api-key>"
# Verified sender address (must match a domain verified in Resend).
EMAIL_FROM="orders@annabarnett.art"

# --- AWS (media pipeline: S3 + CloudFront) -----------------------------------
# Provisioned by Terraform later. The app only needs read/presign access.
AWS_REGION="eu-west-2"
S3_BUCKET_NAME=""
# Public CloudFront domain that serves the art images (e.g. https://dxxxx.cloudfront.net)
CLOUDFRONT_URL=""
# Local dev only — in prod, use an IAM role, NOT static keys.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- Cart --------------------------------------------------------------------
# Secret used to HMAC-sign the cart cookie (tamper detection). In dev a built-in
# fallback is used if blank; in PRODUCTION this is REQUIRED (>=16 chars).
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
CART_SECRET=""

# --- Admin access ------------------------------------------------------------
# Email allow-list for the admin area (comma-separated). Anna only at launch.
ADMIN_EMAILS="anna@annabarnett.art"

# --- Monitoring (Sentry) — added in the productionise phase ------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
