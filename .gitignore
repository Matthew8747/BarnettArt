# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.playwright

# next.js
/.next/
/out/

# local uploads (LocalStorage adapter dev fallback; real media lives in S3)
/public/uploads/

# Raw painting originals (large HEIC/JPEG straight off the camera). These are the
# INPUT to scripts/import-paintings.mjs; the optimised, metadata-stripped outputs
# it generates (public/gallery/ + src/lib/gallery-manifest.json) ARE committed
# and are what the app serves. Keep the heavy originals out of git history — back
# them up separately / move to the S3 media pipeline. To re-import, drop files
# here and run: node scripts/import-paintings.mjs
/paintings/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────────────────────────────────────────────────────────
# SECRETS — never commit. Only *.example files are tracked.
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local
secrets.json
*.key
*.crt
*.p12
*.pfx
service-account*.json
aws-credentials*

# vercel
.vercel

# brainstorming visual-companion working dir
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle
/drizzle/meta/_journal.json.bak

# terraform (infra added in a later phase)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
.terraform.lock.hcl.bak

# docker
docker-compose.override.yml

# editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.gstack/
